# Database
DATABASE_URL=postgresql://costtracker:costtracker@localhost:5432/costtracker

# Security — MUST be changed in production
SECRET_KEY=change-me-in-production

# OIDC (Authentik)
OIDC_ISSUER=https://auth.example.com/application/o/cost-tracker/
OIDC_CLIENT_ID=cost-tracker
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# Logging
LOG_LEVEL=INFO

# Environment: "dev" or "prod"
ENV=dev
